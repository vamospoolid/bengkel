generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String            @id @default(uuid())
  name              String
  username          String            @unique
  password          String
  role              Role              @default(CASHIER)
  status            MechanicStatus    @default(AVAILABLE)
  commissionRate    Float             @default(0.0)
  specialty         String?
  fingerprintId     String?           @unique
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attendanceLogs    Attendance[]
  cashflowLogs      Cashflow[]
  reprintLogs       ReprintLog[]
  stockLogs         StockLog[]
  transactionItems  TransactionItem[]
  createdWorkOrders WorkOrder[]       @relation("CreatedBy")
  assignedTasks     WorkOrder[]       @relation("MechanicTasks")
}

model Product {
  id            String         @id @default(uuid())
  name          String
  brand         String?
  partNumber    String?
  compatibility String?
  category      String
  vehicleType   VehicleType    @default(UMUM)
  stock         Int            @default(0)
  minStock      Int            @default(5)
  purchasePrice Float          @default(0)
  priceNormal   Float
  priceGrosir   Float?
  priceMitra    Float?
  location      String?
  barcode       String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  purchaseItems PurchaseItem[]
  stockLogs     StockLog[]
}

model Service {
  id            String   @id @default(uuid())
  name          String
  price         Float
  estimatedTime String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Customer {
  id           String           @id @default(uuid())
  name         String
  type         CustomerCategory @default(UMUM)
  phone        String?
  whatsapp     String?
  email        String?
  address      String?
  plateNumber  String?
  creditLimit  Float            @default(0)
  currentDebt  Float            @default(0)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  transactions Transaction[]
}

model Supplier {
  id        String             @id @default(uuid())
  name      String
  phone     String?
  address   String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  purchases SupplierPurchase[]
}

model SupplierPurchase {
  id           String         @id @default(uuid())
  invoiceNo    String         @unique
  supplierId   String
  purchaseDate DateTime       @default(now())
  dueDate      DateTime?
  totalAmount  Float
  status       PurchaseStatus @default(LUNAS)
  notes        String?
  invoiceImage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  cashflow     Cashflow?
  items        PurchaseItem[]
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
}

model PurchaseItem {
  id            String           @id @default(uuid())
  purchaseId    String
  productId     String
  quantity      Int
  returnedQty   Int              @default(0)
  purchasePrice Float
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  product       Product          @relation(fields: [productId], references: [id])
  purchase      SupplierPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id           String        @id @default(uuid())
  plateNumber  String        @unique
  model        String
  owner        String
  phone        String?
  vehicleType  String        @default("MOTOR")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  workOrders   WorkOrder[]
}

model Transaction {
  id           String            @id @default(uuid())
  invoiceNo    String            @unique
  vehicleId    String?
  customerId   String?
  totalAmount  Float
  tax          Float             @default(0)
  discount     Float             @default(0)
  paymentType  String            @default("CASH")
  status       String            @default("COMPLETED")
  notes        String?
  reprintCount Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  cashflow     Cashflow?
  reprintLogs  ReprintLog[]
  customer     Customer?         @relation(fields: [customerId], references: [id])
  vehicle      Vehicle?          @relation(fields: [vehicleId], references: [id])
  items        TransactionItem[]
  workOrder    WorkOrder?
}

model ReprintLog {
  id            String      @id @default(uuid())
  transactionId String
  userId        String?
  reason        String?
  printedAt     DateTime    @default(now())
  user          User?       @relation(fields: [userId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  type          ItemType
  itemId        String
  name          String
  price         Float
  purchasePrice Float       @default(0)
  quantity      Int         @default(1)
  returnedQty   Int         @default(0)
  mechanicId    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  mechanic      User?       @relation(fields: [mechanicId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model StockLog {
  id            String   @id @default(uuid())
  productId     String
  type          String
  changeQty     Int
  previousStock Int
  currentStock  Int
  reference     String?
  userId        String?
  createdAt     DateTime @default(now())
  description   String?
  user          User?    @relation(fields: [userId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
}

model Cashflow {
  id               String            @id @default(uuid())
  type             String
  category         String
  amount           Float
  description      String?
  referenceId      String?           @unique
  purchaseId       String?           @unique
  userId           String?
  date             DateTime          @default(now())
  createdAt        DateTime          @default(now())
  user             User?             @relation(fields: [userId], references: [id])
  supplierPurchase SupplierPurchase? @relation(fields: [purchaseId], references: [id])
  transaction      Transaction?      @relation(fields: [referenceId], references: [id])
}

model WorkOrder {
  id            String          @id @default(uuid())
  transactionId String?         @unique
  vehicleId     String?
  plateNumber   String?
  customerName  String?
  model         String?
  vehicleType   String          @default("MOTOR")
  mechanicId    String?
  creatorId     String?
  status        WorkOrderStatus @default(QUEUED)
  complaint     String?
  services      Json?
  partsUsed     Json?
  photos        Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  endTime       DateTime?
  startTime     DateTime?
  creator       User?           @relation("CreatedBy", fields: [creatorId], references: [id])
  mechanic      User?           @relation("MechanicTasks", fields: [mechanicId], references: [id])
  vehicle       Vehicle?        @relation(fields: [vehicleId], references: [id])
  transaction   Transaction?    @relation(fields: [transactionId], references: [id])
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id        String           @id @default(uuid())
  userId    String
  date      DateTime         @default(now())
  clockIn   DateTime         @default(now())
  clockOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  location  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

enum Role {
  ADMIN
  MECHANIC
  CASHIER
}

enum VehicleType {
  MOTOR
  MOBIL
  UMUM
}

enum PurchaseStatus {
  LUNAS
  HUTANG
}

enum MechanicStatus {
  AVAILABLE
  BUSY
  AWAY
}

enum WorkOrderStatus {
  QUEUED
  PROGRESS
  TESTING
  DONE
  ARCHIVED
}

enum ItemType {
  PART
  SERVICE
}

enum AttendanceStatus {
  PRESENT
  LATE
  OVERTIME
  ABSENT
}

enum CustomerCategory {
  UMUM
  GROSIR
  MITRA
}
